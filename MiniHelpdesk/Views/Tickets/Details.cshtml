@model MiniHelpdesk.Models.Ticket

<h2>Szczegóły zgłoszenia</h2>

<div class="card mb-3">
    <div class="card-body">
        <h4>@Model.Title</h4>

        <p>
            <strong>Status:</strong> @Model.Status
        </p>

        <p>
            <strong>Opis:</strong><br />
            @Model.Description
        </p>

        <p>
            <strong>Data utworzenia:</strong> @Model.CreatedAt
        </p>

        @if (Model.Status != "Closed")
        {
            <form asp-action="Close" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-danger">
                    Zamknij zgłoszenie
                </button>
            </form>
        }
    </div>
</div>

<h4>Komentarze</h4>

@if (Model.Comments.Any())
{
    <table class="table">
        <thead>
        <tr>
            <th>Autor</th>
            <th>Komentarz</th>
            <th>Data</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var comment in Model.Comments)
        {
            <tr>
                <td>@comment.Author</td>
                <td>@comment.Content</td>
                <td>@comment.CreatedAt</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>Brak komentarzy.</p>
}

<a asp-action="Index" class="btn btn-secondary">Powrót</a>